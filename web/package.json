{
  "name": "@etherview/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">= 24.18.0",
    "npm": ">= 11.16.0"
  },
  "overrides": {
    "@redocly/openapi-core": {
      "js-yaml": "4.3.0"
    }
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "check:api": "openapi-typescript ../api/openapi.yaml --alphabetize --output src/api/schema.gen.ts --check",
    "generate:api": "openapi-typescript ../api/openapi.yaml --alphabetize --output src/api/schema.gen.ts",
    "lint": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.4",
    "@tanstack/react-router": "1.170.18",
    "echarts": "6.1.0",
    "i18next": "26.3.6",
    "openapi-fetch": "0.17.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-i18next": "17.0.11",
    "viem": "2.55.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "axe-core": "4.12.1",
    "jsdom": "29.1.1",
    "license-checker-rseidelsohn": "5.0.1",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true
  }
}
