# Copy to .env for local Compose use. Never commit live credentials.
POSTGRES_PASSWORD=replace-with-a-local-password
ETHERVIEW_RPC_URLS=http://host.docker.internal:8545
ETHERVIEW_CHAIN_ID=1
ETHERVIEW_CHAIN_GENESIS_HASH=0xd4e56740f876aef8c010b86a40d5f56745a118d0906a34e69aec8c0db1cb8fa3
ETHERVIEW_PORT=8080

# Optional `accelerators` profile only. Etherview correctness does not depend
# on these services.
MINIO_ROOT_USER=etherview
MINIO_ROOT_PASSWORD=replace-with-a-local-password
